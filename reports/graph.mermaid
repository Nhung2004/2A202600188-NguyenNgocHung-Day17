---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	router(router)
	retrieve(retrieve)
	generate(generate)
	update(update)
	__end__([<p>__end__</p>]):::last
	__start__ --> router;
	generate --> update;
	retrieve --> generate;
	router --> retrieve;
	update --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
